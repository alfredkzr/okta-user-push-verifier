# Required — Okta service app (backend API calls)
OKTA_DOMAIN=https://your-org.okta.com
OKTA_CLIENT_ID=your-service-app-client-id
OKTA_PRIVATE_KEY_B64=base64-encoded-pem-private-key
OKTA_KEY_ID=your-jwk-kid

# Required — Okta SPA app (frontend login)
OIDC_ISSUER=https://your-org.okta.com/oauth2/default
OIDC_CLIENT_ID=your-spa-oidc-client-id

# Local development — points to DynamoDB Local
DYNAMODB_ENDPOINT_URL=http://localhost:8002
